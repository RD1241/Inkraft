SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
SUPABASE_SECRET_KEY=sb_secret_your_key_here
STORAGE_PROVIDER=local
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# Fallback model chain (comma-separated) used when GROQ_MODEL hits its per-day token
# limit (429). llama-3.1-8b-instant has a SEPARATE, much larger free-tier daily bucket,
# so extraction keeps working instead of degrading to the rule-based fallback. Set empty
# to disable. NOTE: for real traffic, upgrade Groq to the paid Dev tier (~$0.004/comic) —
# the 100k-tokens/day free cap = only ~15 comics/day across ALL users.
GROQ_FALLBACK_MODELS=llama-3.1-8b-instant
IMAGE_PROVIDER=stable_diffusion

# FAL AI Configuration
FAL_KEY=your_fal_api_key_here
# Per-style text-to-image model. Default (unset) = FLUX dev (fal-ai/flux/dev) for
# every style — the paid bake-off (2026-06-28) showed it follows the prompt far
# better than fast-sdxl (multi-character, props, native B&W manga) at $0.025/img.
# To revert a style to SDXL, set BOTH its endpoint and model, e.g.:
#   FAL_REALISTIC_ENDPOINT=fal-ai/fast-sdxl
#   FAL_REALISTIC_MODEL=SG161222/RealVisXL_V4.0
# For max fidelity on a style, push it to flux-pro:
#   FAL_REALISTIC_ENDPOINT=fal-ai/flux-pro/v1.1
# Override knobs (all optional): FAL_<STYLE>_ENDPOINT / FAL_<STYLE>_MODEL where
# STYLE = MANGA | MANHWA | ANIME | CINEMATIC | REALISTIC.
