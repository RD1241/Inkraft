SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
SUPABASE_SECRET_KEY=sb_secret_your_key_here
STORAGE_PROVIDER=local
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# Fallback model chain (comma-separated) tried in order when GROQ_MODEL hits its
# per-day token limit (429) or is unavailable. Each model has its OWN separate
# free-tier daily token bucket, so chaining several ~multiplies effective free
# capacity AND keeps quality high when the 70B is exhausted (all verified to produce
# clean extraction JSON 2026-06-30). Extraction keeps working instead of degrading to
# the rule-based fallback. Set empty to disable.
# NOTE: paid Groq Dev tier is the real scale fix (~$0.004/comic) but was "temporarily
# unavailable" on the Groq dashboard as of 2026-06-30 — this multi-model chain is the
# free mitigation until it reopens.
GROQ_FALLBACK_MODELS=meta-llama/llama-4-scout-17b-16e-instruct,openai/gpt-oss-120b,llama-3.1-8b-instant
IMAGE_PROVIDER=stable_diffusion

# FAL AI Configuration
FAL_KEY=your_fal_api_key_here
# Per-style text-to-image model. Default (unset) = FLUX dev (fal-ai/flux/dev) for
# every style — the paid bake-off (2026-06-28) showed it follows the prompt far
# better than fast-sdxl (multi-character, props, native B&W manga) at $0.025/img.
# To revert a style to SDXL, set BOTH its endpoint and model, e.g.:
#   FAL_REALISTIC_ENDPOINT=fal-ai/fast-sdxl
#   FAL_REALISTIC_MODEL=SG161222/RealVisXL_V4.0
# For max fidelity on a style, push it to flux-pro:
#   FAL_REALISTIC_ENDPOINT=fal-ai/flux-pro/v1.1
# Override knobs (all optional): FAL_<STYLE>_ENDPOINT / FAL_<STYLE>_MODEL where
# STYLE = MANGA | MANHWA | ANIME | CINEMATIC | REALISTIC.
